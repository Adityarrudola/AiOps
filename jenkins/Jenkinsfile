pipeline {
  agent {
    docker {
      image 'docker:24.0.2-dind'
      args '--privileged -v /var/run/docker.sock:/var/run/docker.sock'
    }
  }

  environment {
    REGISTRY = 'localhost:5000'
    GIT_CREDENTIALS_ID = 'git-credentials'
    REPO_URL = 'https://github.com/your-org/ai-observability.git'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Build Images') {
      steps {
        script {
          sh 'apk update && apk add --no-cache python3 py3-pip git bash'
          def tag = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
          env.IMAGE_TAG = tag
          sh "docker build -t ${REGISTRY}/backend:${tag} -f apps/backend/Dockerfile apps/backend"
          sh "docker build -t ${REGISTRY}/frontend:${tag} -f apps/frontend/Dockerfile apps/frontend"
          sh "docker build -t ${REGISTRY}/aiops:${tag} -f apps/aiops/Dockerfile apps/aiops"
          sh "docker build -t ${REGISTRY}/load-generator:${tag} -f apps/load-generator/Dockerfile apps/load-generator"
          sh "docker push ${REGISTRY}/backend:${tag}"
          sh "docker push ${REGISTRY}/frontend:${tag}"
          sh "docker push ${REGISTRY}/aiops:${tag}"
          sh "docker push ${REGISTRY}/load-generator:${tag}"
        }
      }
    }

    stage('Update GitOps Manifest') {
      steps {
        sh "python3 jenkins/update-helm-values.py ${IMAGE_TAG}"
        sh 'git config user.email "jenkins@local"'
        sh 'git config user.name "jenkins-gitops"'
        sh 'git add charts/backend/values.yaml charts/frontend/values.yaml charts/aiops/values.yaml charts/load-generator/values.yaml'
        sh 'git commit -m "ci: promote images to ${IMAGE_TAG}" || true'
        sh 'git push origin HEAD:main'
      }
    }
  }
}
